# OpenAdSource environment template.
# Copy to ".env" and replace every value below before any non-local deployment.
# Defaults here are intentionally generic placeholders (no high-entropy values).

# ---------- Postgres ----------
# Consumed by the postgres container's entrypoint and by the Go server / worker.
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=openadsource
POSTGRES_PASSWORD=placeholder_password
POSTGRES_DB=openadsource

# Composed URL used by golang-migrate, the Go pgxpool, and Drizzle in the dashboard.
DATABASE_URL=postgres://openadsource:placeholder_password@postgres:5432/openadsource?sslmode=disable

# ---------- Redis ----------
REDIS_URL=redis://redis:6379/0

# ---------- Object storage (optional) ----------
# Phase 1 supports both BYO public URL creatives (no storage needed) and
# internal uploads via this S3-compatible backend. Defaults point at the
# bundled MinIO service.
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_BUCKET=openadsource
S3_ACCESS_KEY_ID=placeholder_key
S3_SECRET_ACCESS_KEY=placeholder_password
S3_FORCE_PATH_STYLE=true
S3_PUBLIC_BASE_URL=http://localhost:9000/openadsource

# Browser-reachable host the dashboard's presigner uses when signing PUT
# URLs. Inside the container the dashboard would otherwise sign URLs against
# http://minio:9000 which the browser can't resolve. Leave empty to fall
# back to S3_ENDPOINT.
S3_PUBLIC_ENDPOINT=http://localhost:9000

# ---------- MinIO bootstrap ----------
# Consumed only by the minio container itself; mirror the S3_* credentials above
# so the bundled stack works out of the box.
MINIO_ROOT_USER=placeholder_key
MINIO_ROOT_PASSWORD=placeholder_password

# ---------- Signing keys ----------
# Phase 2 (dashboard auth) and Phase 4 (tracking pixel HMAC) read these.
# Replace with high-entropy values before any non-local deployment.
JWT_SECRET=placeholder_value
TRACKING_SECRET=placeholder_value

# ---------- Geo + public URL ----------
# Path inside the adserver container to the GeoLite2 .mmdb file (Phase 3).
GEOIP_DB_PATH=/data/GeoLite2-Country.mmdb
# The publicly reachable URL of the adserver (used by the dashboard and
# baked into Impression / track URLs inside the VAST XML). Must match the
# host-mapped port below (ADSERVER_HOST_PORT). Change for production.
PUBLIC_BASE_URL=http://localhost:8088

# ---------- Logging ----------
LOG_LEVEL=info

# ---------- Host port mappings ----------
# Override these if the defaults clash with another local stack.
# (Container-internal ports stay 8080 / 3000 / 80.)
ADSERVER_HOST_PORT=8088
DASHBOARD_HOST_PORT=3000
TEST_PLAYER_HOST_PORT=8090

# ---------- Seed sample source ----------
# Used by the `seed` one-shot service. The seed downloads this MP4 into
# memory and uploads it to MinIO so the internal_s3 ad has bytes to serve.
# If the URL is unreachable, the seed logs a warning and skips the
# internal_s3 ad (the external_url ad still lands and points at this URL).
SAMPLE_MP4_URL=https://www.w3schools.com/html/mov_bbb.mp4
